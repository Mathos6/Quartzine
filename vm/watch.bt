BEGIN {
    printf("Surveillance of the VM\n");
    printf("PID cible = %d\n", $1);
}



tracepoint:syscalls:sys_enter_read
/ pid == $1 /
{
    printf("[%s] read(fd=%d, count=%d)\n",
           comm, args->fd, args->count);
}


tracepoint:syscalls:sys_enter_openat
/ pid == $1 /
{
    printf("[%s] openat(%s)\n",
           comm, str(args->filename));
}


