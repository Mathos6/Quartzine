# Quartzine — Configuration
# ------------------------------

# Comportement au branchement USB
# Valeurs : vm | normal | ask
mode = normal

# Délai avant action automatique (en secondes, 0 = pas de délai)
timeout = 30

# Dossier de sortie des rapports (s'il y en a)
report_dir = /var/log/quartzine/reports
